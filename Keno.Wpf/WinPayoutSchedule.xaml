<!-- Last Edit: 2026-03-15 - WinPayoutSchedule: "You Won!" gold banner; payout ListView with matched row highlighted; 7-second auto-close. -->
<Window x:Class="WinPayoutSchedule"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="You Won!" Height="420" Width="290"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <!-- Gold "You Won" banner -->
        <Border Grid.Row="0" Background="Gold">
            <TextBlock x:Name="TbkWin"
                       FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                       Foreground="Black"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <!-- Game info sub-header -->
        <Border Grid.Row="1" Background="DarkGoldenrod">
            <TextBlock x:Name="TbkGameInfo"
                       FontFamily="Segoe UI" FontSize="9" FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <!-- Payout schedule ListView -->
        <ListView x:Name="LvPayouts" Grid.Row="2"
                  FontFamily="Segoe UI" FontSize="9"
                  Margin="0">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Matched" Width="120"
                                    DisplayMemberBinding="{Binding Matched}" />
                    <GridViewColumn Header="Win" Width="140"
                                    DisplayMemberBinding="{Binding Win}" />
                </GridView>
            </ListView.View>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                            <Setter Property="Background" Value="Gold" />
                            <Setter Property="FontWeight" Value="Bold" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- Countdown -->
        <TextBlock x:Name="TbkCountdown" Grid.Row="3"
                   FontFamily="Segoe UI" FontSize="8" Foreground="Gray" FontStyle="Italic"
                   HorizontalAlignment="Center" Margin="0,3,0,3" />

        <!-- Close button -->
        <Button x:Name="BtnClose" Grid.Row="4" Content="Close"
                FontFamily="Segoe UI" FontSize="9" FontWeight="Bold"
                Click="BtnClose_Click" />
    </Grid>
</Window>