<!-- Last Edit: 2026-03-15 - WinBonusGame: "Bonus Free Game!" notification with 7-second auto-close. -->
<mah:MetroWindow x:Class="WinBonusGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Bonus!" Height="230" Width="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="SeaGreen">
            <TextBlock Text="🎉 Bonus Free Game!"
                       FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="12,8">
            <TextBlock x:Name="TbkInfo"
                       FontFamily="Segoe UI" FontSize="9"
                       TextAlignment="Center" TextWrapping="Wrap" />
            <TextBlock Text="1 free $2 game added!"
                       FontFamily="Segoe UI" FontSize="10" FontWeight="Bold"
                       Foreground="SeaGreen"
                       HorizontalAlignment="Center" Margin="0,6,0,0" />
        </StackPanel>

        <TextBlock x:Name="TbkCountdown" Grid.Row="2"
                   FontFamily="Segoe UI" FontSize="8" Foreground="Gray" FontStyle="Italic"
                   HorizontalAlignment="Center" Margin="0,2,0,4" />

        <Button x:Name="BtnClose" Grid.Row="3" Content="Close"
                FontFamily="Segoe UI" FontSize="10" FontWeight="Bold"
                Click="BtnClose_Click" />
    </Grid>
</mah:MetroWindow>