<!-- Last Edit: 2026-03-15 - WinGameLog: scrollable log viewer with Close and Clear File buttons. -->
<mah:MetroWindow x:Class="WinGameLog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Game Log" Height="550" Width="560"
        WindowStartupLocation="CenterOwner"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition Height="44" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="SteelBlue">
            <TextBlock Text="Game Log"
                       FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <TextBox x:Name="TbxLog" Grid.Row="1"
                 FontFamily="Consolas" FontSize="9"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 AcceptsReturn="True"
                 Margin="4" />

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="8,0">
            <Button x:Name="BtnClearFile" Content="Clear File"
                    FontFamily="Segoe UI" FontSize="9"
                    Width="90" Height="30" Margin="0,0,8,0"
                    Click="BtnClearFile_Click" />
            <Button x:Name="BtnClose" Content="Close"
                    FontFamily="Segoe UI" FontSize="9"
                    Width="90" Height="30"
                    Click="BtnClose_Click" />
        </StackPanel>
    </Grid>
</mah:MetroWindow>