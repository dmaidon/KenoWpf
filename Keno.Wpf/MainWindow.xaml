<!-- Last Edit: 2026-03-16 - Show session summary on close when games were played. -->
<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Keno" Height="498" Width="942"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Closing="MainWindow_Closing">

    <Window.Resources>

        <!-- Default keno cell background — matches WinForms Color.FromArgb(192,255,255) -->
        <SolidColorBrush x:Key="KenoDefaultBrush" Color="#C0FFFF" />

        <!-- Flat clickable button with opacity-based hover/press feedback -->
        <Style x:Key="KenoNumStyle" TargetType="Button">
            <Setter Property="FontFamily"   Value="Segoe UI" />
            <Setter Property="FontSize"     Value="10" />
            <Setter Property="FontWeight"   Value="Bold" />
            <Setter Property="Foreground"   Value="Black" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="BorderBrush"  Value="#888888" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"      Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.40" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Read-only display cell for selected numbers — matches WinForms NumSelect TextBoxes -->
        <Style x:Key="NumSelectStyle" TargetType="Label">
            <Setter Property="FontFamily"   Value="Segoe UI" />
            <Setter Property="FontSize"     Value="11" />
            <Setter Property="FontWeight"   Value="Bold" />
            <Setter Property="Foreground"   Value="Black" />
            <Setter Property="Padding"      Value="0" />
            <Setter Property="Background"   Value="#FFE0C0" />
            <Setter Property="BorderBrush"  Value="#888888" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment"   Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Label">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Game play progress cell — matches WinForms TlpConsecutiveGames label style (Segoe UI Semibold 9pt BoldItalic, FixedSingle border) -->
        <Style x:Key="GamePlayStyle" TargetType="Label">
            <Setter Property="FontFamily"                 Value="Segoe UI Semibold" />
            <Setter Property="FontSize"                   Value="9" />
            <Setter Property="FontWeight"                 Value="Bold" />
            <Setter Property="FontStyle"                  Value="Italic" />
            <Setter Property="Foreground"                 Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
            <Setter Property="Padding"                    Value="0" />
            <Setter Property="Background"                 Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />
            <Setter Property="BorderBrush"                Value="#888888" />
            <Setter Property="BorderThickness"            Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment"   Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Label">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12,0,0,0" Height="458" VerticalAlignment="Center" HorizontalAlignment="Left" Width="930">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="215*" />
            <ColumnDefinition Width="326*" />
            <ColumnDefinition Width="169*" />
            <ColumnDefinition Width="220*" />
            <!--<ColumnDefinition Width="205*" />-->
        </Grid.ColumnDefinitions>

        <!-- Payout schedule panel — left column (≈193 DIP wide), matches WinForms GbxPayoutSchedule -->
        <GroupBox x:Name="GbxPayoutSchedule"
                  HorizontalAlignment="Left"
                  Width="193"
                  FontFamily="Segoe UI" FontSize="9" FontWeight="Bold" Margin="0,0,0,230">
            <GroupBox.Header>
                <TextBlock x:Name="TbkPayoutHeader"
                           Text="Payout Schedule"
                           FontFamily="Segoe UI" FontSize="9" FontWeight="Bold" />
            </GroupBox.Header>
            <RichTextBox x:Name="RtbPayoutSchedule"
                         IsReadOnly="True"
                         FontFamily="Consolas" FontSize="8.5"
                         FontWeight="Normal"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled" Height="267" />
        </GroupBox>

        <!-- 8 rows × 10 cols = numbers 1–80; each cell 60×60 DIP                  -->
        <!-- Split into two 4-row grids matching WinForms TlpKenoGridTop/Bottom     -->
        <Border BorderBrush="#888888" BorderThickness="2"
                HorizontalAlignment="Center" VerticalAlignment="Top" Height="273" Width="304" Grid.Column="1">
            <StackPanel Orientation="Vertical">
                <UniformGrid x:Name="KenoGridTop"
                             Rows="4" Columns="10"
                             Width="300" Height="120">
                    <UniformGrid.Style>
                        <Style />
                    </UniformGrid.Style>
                    <UniformGrid.Effect>
                        <DropShadowEffect />
                    </UniformGrid.Effect>
                </UniformGrid>
                <TextBlock Text="Select your numbers then click PLAY"
                           FontFamily="Segoe UI" FontSize="13" FontStyle="Italic"
                           Foreground="#FF076838"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,6" FontWeight="Bold" />
                <UniformGrid x:Name="KenoGridBottom"
                             Rows="4" Columns="10"
                             Width="300" Height="120">
                    <UniformGrid.Effect>
                        <DropShadowEffect />
                    </UniformGrid.Effect>
                </UniformGrid>
            </StackPanel>
        </Border>

        <Border BorderBrush="#888888" BorderThickness="2"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,300,0,0" Height="64" Width="304" Grid.Column="1">
            <StackPanel Orientation="Vertical">
                <UniformGrid x:Name="KenoGridPlayed"
                             Rows="2" Columns="10"
                             Width="300" Height="60">
                    <UniformGrid.Effect>
                        <DropShadowEffect />
                    </UniformGrid.Effect>
                </UniformGrid>
            </StackPanel>
        </Border>
        <Button x:Name="BtnPlay" Content="PLAY" Click="BtnPlay_Click" HorizontalAlignment="Left" Margin="40,338,0,0" VerticalAlignment="Top" Width="71" Background="#FFEE614E" FontWeight="Bold" Height="20" />
        <Button x:Name="BtnCLEAR" Content="CLEAR" Click="BtnClear_Click" HorizontalAlignment="Left" Margin="40,363,0,0" VerticalAlignment="Top" Width="71" Background="#FFEECF4E" FontWeight="Bold" Height="20" />
        <Button x:Name="BtnFreeGames" Content="Free Games Won" HorizontalAlignment="Center" Margin="0,278,0,0" VerticalAlignment="Top" Background="#FF086717" Foreground="#FFF1E3C2" FontSize="9" Height="16" Width="70" Grid.Column="1" />
        <StatusBar x:Name="StatBar1" VerticalAlignment="Bottom" Margin="0,0,0,19" Grid.ColumnSpan="4" Height="21" Background="#FFDCF8F8" HorizontalAlignment="Left" Width="930">
            <!-- SbiCpy must be declared first so DockPanel.Dock=Right reserves right space -->
            <StatusBarItem x:Name="SbiCpy" Content="cpy"  DockPanel.Dock="Right" VerticalAlignment="Center" FontSize="8" Foreground="#FF640909" FontStyle="Italic" FontWeight="Bold" Height="18" Width="304" />
            <StatusBarItem x:Name="SbiPicks"  Content="Picks: 0"    VerticalAlignment="Center" FontSize="10" FontWeight="Bold" />
            <Separator />
            <StatusBarItem x:Name="SbiMatches" Content="Matches: 0"  VerticalAlignment="Center" FontSize="10" FontWeight="Bold" />
            <Separator />
            <StatusBarItem x:Name="SbiPayout"  Content="Payout: $0.00" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Margin="0,-1,0,0" Width="790" />
        </StatusBar>
        <StatusBar x:Name="StatBar2" VerticalAlignment="Top" Margin="0,390,0,0" Height="21" Background="#FFCAF29B" Grid.ColumnSpan="4">
            <!-- Right-docked items must be declared first for DockPanel layout -->
            <StatusBarItem x:Name="SbiProgressiveJackpot" DockPanel.Dock="Right"
                           Cursor="Hand" Padding="4,0"
                           MouseLeftButtonDown="SbiProgressiveJackpot_MouseDown" BorderBrush="{DynamicResource KenoDefaultBrush}">
                <TextBlock x:Name="TbkProgressiveJackpot" Text="Progressive Jackpot: $0"
                           FontSize="9" FontWeight="Bold" Foreground="#FFC000C0"
                           VerticalAlignment="Center"  Width="160" />
            </StatusBarItem>
            <StatusBarItem x:Name="SbiSummary" DockPanel.Dock="Right"
                           Cursor="Hand" Padding="0"
                           MouseLeftButtonDown="SbiSummary_MouseDown">
                <Border Background="MistyRose" BorderBrush="#888888" BorderThickness="1" Padding="4,0">
                    <TextBlock Text="Summary" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" />
                </Border>
            </StatusBarItem>
            <StatusBarItem x:Name="SbiGameLog" DockPanel.Dock="Right"
                           Cursor="Hand" Padding="0"
                           MouseLeftButtonDown="SbiGameLog_MouseDown">
                <Border Background="#FFC0C0FF" BorderBrush="#888888" BorderThickness="1" Padding="4,0">
                    <TextBlock Text="Game Log" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" />
                </Border>
            </StatusBarItem>
            <StatusBarItem x:Name="SbiHelp" DockPanel.Dock="Right"
                           Cursor="Hand" Padding="0"
                           MouseLeftButtonDown="SbiHelp_MouseDown">
                <Border Background="#FFFFC0C0" BorderBrush="#888888" BorderThickness="1" Padding="4,0">
                    <TextBlock Text="Help" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" />
                </Border>
            </StatusBarItem>
            <StatusBarItem x:Name="SbiCurrentStreak" DockPanel.Dock="Left" Content="Streak: —" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" />
            <StatusBarItem x:Name="SbiBestStreak" Content="Best: 0W" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" />
        </StatusBar>
        <GroupBox x:Name="GbxBank" Header="Bank" Margin="0,-4,0,0" HorizontalAlignment="Center" Width="150" VerticalAlignment="Top"
                  Background="#FF538697" FontWeight="Bold" Height="138" Grid.Column="2">
            <StackPanel Margin="4,2,4,4">
                <Label x:Name="LblBank" Content="$0"
                       HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                       VerticalContentAlignment="Center" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold"
                       Background="#FF8FF3E4" BorderBrush="#888888" BorderThickness="1"
                       Height="25" Padding="0" />
                <TextBlock Text="Winnings" HorizontalAlignment="Center"
                           FontFamily="Segoe UI" FontSize="9" FontWeight="Bold" FontStyle="Italic"
                           Margin="0,4,0,1" />
                <Label x:Name="LblWinnings" Content="$0"
                       HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                       VerticalContentAlignment="Center" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" FontStyle="Italic"
                       Background="#FF80FF80" Foreground="Black"
                       BorderBrush="#888888" BorderThickness="1" Height="25" Padding="0" />
                <TextBlock Text="Wager" HorizontalAlignment="Center"
                           FontFamily="Segoe UI" FontSize="9" FontWeight="Bold" FontStyle="Italic"
                           Margin="0,4,0,1" />
                <Label x:Name="LblWagerTotal" Content="$0"
                       HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                       VerticalContentAlignment="Center" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" FontStyle="Italic"
                       Background="DarkOrange" Foreground="Black"
                       BorderBrush="#888888" BorderThickness="1" Height="25" Padding="0" />
            </StackPanel>
        </GroupBox>
        <!-- Wager selector — mirrors WinForms GbxWager (2 cols: $1–$20 left, $25–$200 right) -->
        <GroupBox x:Name="GbxWager" Header="Wager"
                  HorizontalAlignment="Center" VerticalAlignment="Top"
                  Margin="0,135,0,0" Width="150"
                  Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}"
                  FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Height="163" Grid.Column="2">
            <StackPanel Margin="4,2,4,4">
                <UniformGrid Columns="2">
                    <RadioButton x:Name="RbWager1"   Content="$1"   Tag="1"   GroupName="Wager" IsChecked="True" Checked="RbWager_Checked" Margin="0,1" />
                    <RadioButton x:Name="RbWager25"  Content="$25"  Tag="25"  GroupName="Wager" Checked="RbWager_Checked" Margin="0,1" />
                    <RadioButton x:Name="RbWager2"   Content="$2"   Tag="2"   GroupName="Wager" Checked="RbWager_Checked" Margin="0,1" />
                    <RadioButton x:Name="RbWager30"  Content="$30"  Tag="30"  GroupName="Wager" Checked="RbWager_Checked" Margin="0,1" />
                    <RadioButton x:Name="RbWager3"   Content="$3"   Tag="3"   GroupName="Wager" Checked="RbWager_Checked" Margin="0,1" />
                    <RadioButton x:Name="RbWager40"  Content="$40"  Tag="40"  GroupName="Wager" Checked="RbWager_Checked" Margin="0,1" />
                    <RadioButton x:Name="RbWager5"   Content="$5"   Tag="5"   GroupName="Wager" Checked="RbWager_Checked" Margin="0,1" />
                    <RadioButton x:Name="RbWager50"  Content="$50"  Tag="50"  GroupName="Wager" Checked="RbWager_Checked" Margin="0,1" />
                    <RadioButton x:Name="RbWager10"  Content="$10"  Tag="10"  GroupName="Wager" Checked="RbWager_Checked" Margin="0,1" />
                    <RadioButton x:Name="RbWager100" Content="$100" Tag="100" GroupName="Wager" Checked="RbWager_Checked" Margin="0,1" />
                    <RadioButton x:Name="RbWager15"  Content="$15"  Tag="15"  GroupName="Wager" Checked="RbWager_Checked" Margin="0,1" />
                    <RadioButton x:Name="RbWager150" Content="$150" Tag="150" GroupName="Wager" Checked="RbWager_Checked" Margin="0,1" />
                    <RadioButton x:Name="RbWager20"  Content="$20"  Tag="20"  GroupName="Wager" Checked="RbWager_Checked" Margin="0,1" />
                    <RadioButton x:Name="RbWager200" Content="$200" Tag="200" GroupName="Wager" Checked="RbWager_Checked" Margin="0,1" />
                </UniformGrid>
                <Separator Margin="0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Custom:" FontSize="9" FontWeight="Normal"
                           Padding="0,0,4,0" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" x:Name="TxtSpecialWager" Text="0"
                             TextAlignment="Right" FontSize="10" FontWeight="Normal"
                             VerticalContentAlignment="Center"
                             TextChanged="TxtSpecialWager_TextChanged" />
                </Grid>
            </StackPanel>
        </GroupBox>
        <!-- Consecutive games — mirrors WinForms GbxConsecutiveGames 5-col layout -->
        <GroupBox x:Name="GbxConsecutiveGames" Header="Consecutive Games"
                  Margin="-2,225,10,0" VerticalAlignment="Top"
                  Background="#FFE9F6D5"
                  FontFamily="Segoe UI" FontSize="9" FontWeight="Bold" Height="104">
            <StackPanel Margin="4,2,4,4">
                <UniformGrid Columns="5">
                    <!-- Row 1 -->
                    <RadioButton x:Name="RbConsecutive2"  Content="2"  Tag="2"  GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <RadioButton x:Name="RbConsecutive6"  Content="6"  Tag="6"  GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <RadioButton x:Name="RbConsecutive10" Content="10" Tag="10" GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <RadioButton x:Name="RbConsecutive14" Content="14" Tag="14" GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <RadioButton x:Name="RbConsecutive18" Content="18" Tag="18" GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <!-- Row 2 -->
                    <RadioButton x:Name="RbConsecutive3"  Content="3"  Tag="3"  GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <RadioButton x:Name="RbConsecutive7"  Content="7"  Tag="7"  GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <RadioButton x:Name="RbConsecutive11" Content="11" Tag="11" GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <RadioButton x:Name="RbConsecutive15" Content="15" Tag="15" GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <RadioButton x:Name="RbConsecutive19" Content="19" Tag="19" GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <!-- Row 3 -->
                    <RadioButton x:Name="RbConsecutive4"  Content="4"  Tag="4"  GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <RadioButton x:Name="RbConsecutive8"  Content="8"  Tag="8"  GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <RadioButton x:Name="RbConsecutive12" Content="12" Tag="12" GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <RadioButton x:Name="RbConsecutive16" Content="16" Tag="16" GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <RadioButton x:Name="RbConsecutive20" Content="20" Tag="20" GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <!-- Row 4 -->
                    <RadioButton x:Name="RbConsecutive5"  Content="5"  Tag="5"  GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <RadioButton x:Name="RbConsecutive9"  Content="9"  Tag="9"  GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <RadioButton x:Name="RbConsecutive13" Content="13" Tag="13" GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                    <RadioButton x:Name="RbConsecutive17" Content="17" Tag="17" GroupName="Consec" Checked="RbConsecutive_Checked" Margin="1" />
                </UniformGrid>
                <TextBlock x:Name="TbkBonusMultiplier" Text="Bonus: 1×"
                           FontSize="8" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,3,0,0" />
            </StackPanel>
        </GroupBox>

        <!-- Game play progress tracker + legend — mirrors WinForms TlpConsecutiveGames + LlbFirstLegend + LblLastLegend -->
        <!-- Cells (LblGamePlay1–20) are built in code-behind via BuildGamePlayGrid().                                     -->
        <StackPanel x:Name="StkPnlGamesPlayed" HorizontalAlignment="Center" VerticalAlignment="Top"
                    Margin="0,3,0,0" Grid.Column="3" Height="59" Width="130">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TbkFirstLegend" Text="  First = ♥   "
                           Foreground="Red"
                           FontFamily="Segoe UI" FontSize="9" FontWeight="Bold" />
                <TextBlock x:Name="TbkLastLegend" Text="Last = ♦"
                           Foreground="Blue"
                           FontFamily="Segoe UI" FontSize="9" FontWeight="Bold" />
            </StackPanel>
            <UniformGrid x:Name="TlpGamePlay"
                         Rows="2" Columns="10"
                         Height="45" Width="130" />
        </StackPanel>

        <!-- Save favorites — mirrors WinForms BtnSaveFavorites -->
        <Button x:Name="BtnSaveFavorites" Content="Save My Favorites"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,306,0,0" Width="114" Height="20"
                Background="MistyRose" FontFamily="Segoe UI" FontSize="9" FontWeight="Bold"
                Click="BtnSaveFavorites_Click" Grid.Column="2" />

        <!-- Draw speed selector — mirrors WinForms TableLayoutPanel2 -->
        <GroupBox x:Name="GbxDrawSpeed" Header="Draw Speed"
                  HorizontalAlignment="Center" VerticalAlignment="Top"
                  Margin="0,331,0,0"
                  Background="#FFC0FFC0" FontFamily="Segoe UI" FontSize="9" FontWeight="Bold" Grid.Column="2" Height="57" Width="119">
            <Grid Margin="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border Grid.Column="0" Grid.Row="0" Background="#FFC0FFFF">
                    <RadioButton x:Name="RbDrawSpeedSlow" Tag="1000" GroupName="DrawSpeed"
                                 Checked="RbDrawSpeed_Checked"
                                 HorizontalAlignment="Center" Margin="4,2" />
                </Border>
                <Border Grid.Column="1" Grid.Row="0" Background="#FFFFC080">
                    <RadioButton x:Name="RbDrawSpeedMedium" Tag="500" GroupName="DrawSpeed"
                                 IsChecked="True" Checked="RbDrawSpeed_Checked"
                                 HorizontalAlignment="Center" Margin="4,2" />
                </Border>
                <Border Grid.Column="2" Grid.Row="0" Background="#FFFF8080">
                    <RadioButton x:Name="RbDrawSpeedFast" Tag="200" GroupName="DrawSpeed"
                                 Checked="RbDrawSpeed_Checked"
                                 HorizontalAlignment="Center" Margin="4,2" />
                </Border>
                <Border Grid.Column="0" Grid.Row="1" Background="#FFC0FFFF">
                    <TextBlock Text="Slow" HorizontalAlignment="Center"
                               FontWeight="Bold" Padding="4,2" />
                </Border>
                <Border Grid.Column="1" Grid.Row="1" Background="#FFFFC080">
                    <TextBlock Text="Med" HorizontalAlignment="Center"
                               FontWeight="Bold" Padding="4,2" />
                </Border>
                <Border Grid.Column="2" Grid.Row="1" Background="#FFFF8080">
                    <TextBlock Text="Fast" HorizontalAlignment="Center"
                               FontWeight="Bold" Padding="4,2" />
                </Border>
                <Border Grid.Column="3" Grid.Row="0" Background="#FFFF80FF">
                    <RadioButton x:Name="RbDrawSpeedSS" Tag="0" GroupName="DrawSpeed"
                                 Checked="RbDrawSpeed_Checked"
                                 HorizontalAlignment="Center" Margin="4,2" />
                </Border>
                <Border Grid.Column="3" Grid.Row="1" Background="#FFFF80FF">
                    <TextBlock Text="SS" HorizontalAlignment="Center"
                               FontWeight="Bold" Padding="4,2" />
                </Border>
            </Grid>
        </GroupBox>

        <!-- Special Play — mirrors WinForms GbxSpecialPlay -->
        <GroupBox x:Name="GbxSpecialPlay" Header="Special Play"
                  HorizontalAlignment="Center" VerticalAlignment="Top" Width="154" Height="323"
                  Background="Silver" FontFamily="Segoe UI" FontSize="8" FontWeight="Bold" Grid.Column="3" Margin="4,61,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Height="312" Margin="0,0,22,0">
                <StackPanel Margin="4,2,4,4">
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,4">
                        <Button x:Name="BtnQuickPick" Content="Quick Pick" Width="69" Height="20"
                                Background="MistyRose" FontFamily="Segoe UI" FontSize="8" FontWeight="Bold"
                                Click="BtnQuickPick_Click" />
                        <TextBox x:Name="TxtQuickPickCount" Text="1" Width="42" Height="20"
                                 TextAlignment="Center" FontSize="10" FontWeight="Normal"
                                 VerticalContentAlignment="Center" Margin="4,0,0,0"
                                 TextChanged="TxtQuickPickCount_TextChanged" />
                    </StackPanel>
                    <CheckBox x:Name="ChkMultiplierKeno" Content="Multiplier: 1×" Margin="2,1"
                              Foreground="Red" FontFamily="Segoe UI" FontSize="8" FontWeight="Bold"
                              Checked="ChkMultiplierKeno_Changed" Unchecked="ChkMultiplierKeno_Changed" />
                    <CheckBox x:Name="ChkFirstLastPlay" Content="First/Last ($1)" Margin="2,1"
                              Foreground="Teal" FontFamily="Segoe UI" FontSize="8" FontWeight="Bold"
                              Checked="ChkFirstLastPlay_Changed" Unchecked="ChkFirstLastPlay_Changed" />
                    <CheckBox x:Name="ChkWayTicket" Content="Way Ticket" Margin="2,1"
                              Foreground="#FFC04000" FontFamily="Segoe UI" FontSize="8" FontWeight="Bold"
                              Checked="ChkWayTicket_Changed" Unchecked="ChkWayTicket_Changed" />
                    <Label x:Name="LblWayTicketSummary" Content="—"
                           HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                           FontFamily="Segoe UI" FontSize="8" FontStyle="Italic"
                           Foreground="#FFC04000" Padding="2,0" />
                    <CheckBox x:Name="ChkPowerball" Content="Powerball (×4)" Margin="2,1"
                              Foreground="#FF80FFFF" FontFamily="Segoe UI" FontSize="8" FontWeight="Bold"
                              Checked="ChkPowerball_Changed" Unchecked="ChkPowerball_Changed" />
                    <Label x:Name="LblPowerballValue" Content="—"
                           HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                           FontFamily="Segoe UI" FontSize="8" FontStyle="Italic"
                           Foreground="#FF80FFFF" Padding="2,0" />
                    <Separator Margin="0,4" />
                    <Button x:Name="BtnBullseye" Content="Play Bullseye" Height="20"
                            HorizontalAlignment="Stretch" Margin="0,2"
                            Background="MistyRose" FontFamily="Segoe UI" FontSize="8" FontWeight="Bold"
                            Click="BtnBullseye_Click" Width="77" RenderTransformOrigin="-0.5,0.629" />
                    <Button x:Name="BtnPlayFavorites" Content="Play My Favorites" Height="20"
                            HorizontalAlignment="Stretch" Margin="0,2"
                            Background="MistyRose" FontFamily="Segoe UI" FontSize="8" FontWeight="Bold"
                            Click="BtnPlayFavorites_Click" Width="77" />
                    <Button x:Name="BtnReplayLastGame" Content="Replay Last Game" Height="20"
                            HorizontalAlignment="Stretch" Margin="0,2"
                            Background="MistyRose" FontFamily="Segoe UI" FontSize="8" FontWeight="Bold"
                            Click="BtnReplayLastGame_Click" Width="77" />
                    <Separator Margin="0,4" />
                    <TextBlock Text="Play Quadrants/Halves"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               FontFamily="Segoe UI Semibold" FontSize="8" FontWeight="Bold"
                               Margin="0,2,0,4" Width="134" />
                    <UniformGrid x:Name="TlpQuadrants" Rows="2" Columns="2" Width="79">
                        <Button x:Name="BtnQuadrant1" Content="1" Tag="1" Height="36"
                                Background="#FFFFC0FF" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold"
                                Click="BtnQuadrant_Click" Width="36" />
                        <Button x:Name="BtnQuadrant2" Content="2" Tag="2" Height="36"
                                Background="#FFFFC0FF" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold"
                                Click="BtnQuadrant_Click" Width="36" />
                        <Button x:Name="BtnQuadrant3" Content="3" Tag="3" Height="36"
                                Background="#FFFFC0FF" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold"
                                Click="BtnQuadrant_Click" Width="36" />
                        <Button x:Name="BtnQuadrant4" Content="4" Tag="4" Height="36"
                                Background="#FFFFC0FF" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold"
                                Click="BtnQuadrant_Click" Width="36" />
                    </UniformGrid>
                </StackPanel>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</Window>