<!-- Last Edit: 2026-03-15 - WinSessionSummary: session stats with net P/L colour coding; Close button. -->
<Window x:Class="WinSessionSummary"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Summary" Height="310" Width="195"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid HorizontalAlignment="Left" Width="185">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition Height="44" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="SteelBlue" Height="NaN" Margin="0,0,-10,0" Width="NaN">
            <TextBlock Text="Session Summary"
                       FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <Grid Grid.Row="1" Margin="12,10,40,0" Height="205" VerticalAlignment="Top" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Net Profit / Loss:" Style="{StaticResource SumCapStyle}" />
            <TextBlock x:Name="TbkNetPL"  Grid.Row="0" Grid.Column="1" Style="{StaticResource SumValStyle}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Games Played:" Style="{StaticResource SumCapStyle}" />
            <TextBlock x:Name="TbkGames"  Grid.Row="1" Grid.Column="1" Style="{StaticResource SumValStyle}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Win Rate:" Style="{StaticResource SumCapStyle}" />
            <TextBlock x:Name="TbkWinRate" Grid.Row="2" Grid.Column="1" Style="{StaticResource SumValStyle}" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Best Single Payout:" Style="{StaticResource SumCapStyle}" />
            <TextBlock x:Name="TbkBest" Grid.Row="3" Grid.Column="1" Style="{StaticResource SumValStyle}" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Free Games Earned:" Style="{StaticResource SumCapStyle}" />
            <TextBlock x:Name="TbkFreeGames" Grid.Row="4" Grid.Column="1" Style="{StaticResource SumValStyle}" />

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Total Wagered:" Style="{StaticResource SumCapStyle}" />
            <TextBlock x:Name="TbkWagered" Grid.Row="5" Grid.Column="1" Style="{StaticResource SumValStyle}" />

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Total Payout:" Style="{StaticResource SumCapStyle}" />
            <TextBlock x:Name="TbkPayout" Grid.Row="6" Grid.Column="1" Style="{StaticResource SumValStyle}" />

            <TextBlock Grid.Row="7" Grid.Column="0" Text="Return %:" Style="{StaticResource SumCapStyle}" />
            <TextBlock x:Name="TbkReturn" Grid.Row="7" Grid.Column="1" Style="{StaticResource SumValStyle}" />
        </Grid>

        <Button x:Name="BtnClose" Grid.Row="2" Content="Close"
                FontFamily="Segoe UI" FontSize="9" FontWeight="Bold" Margin="0,14,-10,8"
                Click="BtnClose_Click" />
    </Grid>
</Window>