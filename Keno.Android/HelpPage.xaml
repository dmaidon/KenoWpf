<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Keno.Android.HelpPage"
             BackgroundColor="#F0F0F0">
    <!-- Last Edit: 2026-03-25 02:21 PM - In-app help page: board, wager, quick pick, play/replay/clear, consecutive games, side bets, favorites, bank. -->

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- Row 0: Header -->
        <Grid ColumnDefinitions="*,Auto"
              BackgroundColor="#2196A6"
              Padding="12,8,4,8">
            <Label Text="HOW TO PLAY"
                   FontSize="16" FontAttributes="Bold" TextColor="White"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    x:Name="BtnClose"
                    Text="✕"
                    BackgroundColor="Transparent"
                    BorderWidth="0"
                    TextColor="White"
                    FontSize="18" FontAttributes="Bold"
                    WidthRequest="46" HeightRequest="46"
                    Padding="0"
                    Clicked="BtnClose_Clicked" />
        </Grid>

        <!-- Row 1: Scrollable help content -->
        <ScrollView Grid.Row="1"
                    VerticalScrollBarVisibility="Always">
            <VerticalStackLayout x:Name="HelpContent"
                                 Spacing="6"
                                 Padding="12,10,12,16" />
        </ScrollView>
    </Grid>
</ContentPage>