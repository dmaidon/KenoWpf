<?xml version="1.0" encoding="utf-8" ?>
<!-- Last Edit: 2026-03-25 02:21 PM - Payout schedule sheet: pick selector (1–20) + match→payout table. -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Keno.Android.PayoutSchedulePage"
             BackgroundColor="#F0F0F0">

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0">

        <!-- Row 0: Header -->
        <Grid ColumnDefinitions="*,Auto"
              BackgroundColor="#2196A6"
              Padding="12,8,4,8">
            <Label Text="PAYOUT SCHEDULE"
                   FontSize="16" FontAttributes="Bold" TextColor="White"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    x:Name="BtnClose"
                    Text="✕"
                    BackgroundColor="Transparent"
                    BorderWidth="0"
                    TextColor="White"
                    FontSize="18" FontAttributes="Bold"
                    WidthRequest="46" HeightRequest="46"
                    Padding="0"
                    Clicked="BtnClose_Clicked" />
        </Grid>

        <!-- Row 1: Pick selector strip -->
        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    BackgroundColor="#1A7A8A"
                    HeightRequest="44"
                    HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout x:Name="PickButtonsLayout"
                                   Spacing="3"
                                   Padding="6,6,6,6"
                                   VerticalOptions="Center" />
        </ScrollView>

        <!-- Row 2: Payout table -->
        <ScrollView Grid.Row="2"
                    VerticalScrollBarVisibility="Always">
            <VerticalStackLayout x:Name="PayoutContent"
                                 Spacing="2"
                                 Padding="12,10,12,12" />
        </ScrollView>
    </Grid>
</ContentPage>